# 复制为 .env 后填写（勿提交 .env）

# Userbot — https://my.telegram.org/apps
API_ID=
API_HASH=
PHONE_NUMBER=+86xxxxxxxxxx

# 工作群 ID（负数）。仅此处列出的会话会触发打包/APK
CHAT_ID=-100xxxxxxxx
# CHAT_IDS=-100aaa,-100bbb

PROXY_TYPE=5
PROXY_HOST=127.0.0.1
PROXY_PORT=7890

BUILD_PROJECT_PATH=../WG-WEB
BUILD_PROJECT_PATH_B=../WGAME-WEB
ALLOWED_USERS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
S3_BUCKET=

# 功能开关（true / false）
ENABLE_LOG_ALL_MESSAGES=false
ENABLE_APK_CRON=true
# 压缩包入队与配置检测可独立：仅入队可设 ANALYZE=false、PENDING=true
ENABLE_ZIP_ANALYZE=true
ENABLE_ZIP_PENDING=true
ENABLE_MANUAL_DETECT=false
ENABLE_BUILD_ZIP_ANALYZE=false
ENABLE_AUTO_BRANCHLIST_FROM_GROUP=true
APK_SKIP_IF_ALREADY_BUILT=true

APK_MAX_CONCURRENCY=2
APK_BATCH_RETRY_DELAY_MS=3000
