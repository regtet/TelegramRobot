# 复制为 .env 后填写（勿提交 .env）

# Userbot — https://my.telegram.org/apps
API_ID=
API_HASH=
PHONE_NUMBER=+86xxxxxxxxxx

# 工作群 ID（负数）。仅此处列出的会话会触发打包/APK
CHAT_ID=-100xxxxxxxx
# CHAT_IDS=-100aaa,-100bbb

PROXY_TYPE=5
PROXY_HOST=127.0.0.1
PROXY_PORT=7890

BUILD_PROJECT_PATH=../WG-WEB
BUILD_PROJECT_PATH_B=../WGAME-WEB
# 自动打包构建命令（默认 npm run build:secure = 构建 + 混淆，需等待整条命令结束后再打 zip）
# BUILD_COMMAND=npm run build:secure
# dist 打 RAR（WinRAR 默认压缩，需本机安装）
# RAR_COMMAND=C:\Program Files\WinRAR\Rar.exe
ALLOWED_USERS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
S3_BUCKET=

# 功能开关（true / false）
ENABLE_LOG_ALL_MESSAGES=false
ENABLE_APK_CRON=true
# 压缩包入队与配置检测可独立：仅入队可设 ANALYZE=false、PENDING=true
ENABLE_ZIP_ANALYZE=true
ENABLE_ZIP_PENDING=true
ENABLE_MANUAL_DETECT=false
# 群内复刻台公告自动解析（与已废弃的 branchList.json 无关）
ENABLE_AUTO_BRANCHLIST_FROM_GROUP=true
# 复刻台公告第 1 条（域名）与第 2 条（分包行）配对等待时间（毫秒），超时丢弃 pending
BRANCH_ANNOUNCE_PENDING_TTL_MS=14400000
APK_SKIP_IF_ALREADY_BUILT=true

APK_MAX_CONCURRENCY=2
APK_BATCH_RETRY_DELAY_MS=3000

# 群内「穿透 分支名」：启动 dev + 临时公网链接（分钟）
# 推荐安装 cloudflared 后配置路径（比 npx 更快更稳）：https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/
DEV_TUNNEL_PORT=8088
DEV_TUNNEL_DURATION_MS=600000
# 是否允许群内所有人触发「穿透 分支名」（false 时仅 ALLOWED_USERS）
ENABLE_TUNNEL_ALL_USERS=false
# 相对路径相对 telegram-bot 目录；勿写成 cloudflared.exe.exe（浏览器重复后缀）
# CLOUDFLARED_PATH=./cloudflared.exe
# 未设 CLOUDFLARED_PROXY 时，是否自动用 PROXY_HOST:PROXY_PORT（Clash 混合端口）
CLOUDFLARED_AUTO_PROXY=true
# CLOUDFLARED_PROXY=http://127.0.0.1:7890
# CLOUDFLARED_RETRY_COUNT=3
# CLOUDFLARED_RETRY_DELAY_MS=4000
# CLOUDFLARED_EDGE_WAIT_MS=120000
# CLOUDFLARED_PROTOCOL=http2
# cloudflared 失败时是否尝试 localtunnel（默认 false；loca.lt 需填公网 IP，不适合分享）
# TUNNEL_FALLBACK_LOCALTUNNEL=false
